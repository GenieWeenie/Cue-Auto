# ============================================================
# CueAgent Production Environment Template
# Copy to .env.production before running docker compose.
# ============================================================

# Compose runtime mode:
# - polling: Telegram bot polling loop (recommended default)
# - loop: autonomous Ralph loop only
# - once: single loop iteration and exit
CUE_RUN_MODE=polling

# --- Required: Telegram ---
CUE_TELEGRAM_BOT_TOKEN=replace-with-bot-token
CUE_TELEGRAM_ADMIN_CHAT_ID=123456789

# --- Required: at least one LLM provider ---
# Option A: OpenAI
CUE_OPENAI_API_KEY=replace-with-openai-key
CUE_OPENAI_MODEL=gpt-4o
CUE_OPENAI_BASE_URL=https://api.openai.com

# Option B: Anthropic (optional fallback)
CUE_ANTHROPIC_API_KEY=
CUE_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Option C: OpenRouter (optional fallback)
CUE_OPENROUTER_API_KEY=
CUE_OPENROUTER_MODEL=openai/gpt-4o
CUE_OPENROUTER_BASE_URL=https://openrouter.ai/api

# Option D: LM Studio local endpoint (optional fallback)
CUE_LMSTUDIO_BASE_URL=http://localhost:1234
CUE_LMSTUDIO_MODEL=local-model

# --- Runtime behavior ---
CUE_LLM_TEMPERATURE=0.0
CUE_LLM_TIMEOUT_SECONDS=60
CUE_REQUIRE_APPROVAL=true
CUE_HIGH_RISK_TOOLS=["run_shell","write_file","send_telegram"]

# --- Storage and content paths (mapped in docker-compose) ---
CUE_STATE_DB_PATH=/data/cue_state.db
CUE_SKILLS_DIR=/app/skills
CUE_SOUL_MD_PATH=/app/SOUL.md

# --- Optional loop/scheduler settings ---
CUE_LOOP_ENABLED=true
CUE_LOOP_INTERVAL_SECONDS=30
CUE_HEARTBEAT_ENABLED=false
CUE_DAILY_SUMMARY_CRON=0 8 * * *

# --- Health endpoint used by container checks ---
CUE_HEALTHCHECK_ENABLED=true
CUE_HEALTHCHECK_HOST=0.0.0.0
CUE_HEALTHCHECK_PORT=8080

# --- Retry and resilience ---
CUE_RETRY_TOOL_ATTEMPTS=3
CUE_RETRY_TELEGRAM_ATTEMPTS=5
CUE_RETRY_LLM_ATTEMPTS=3
CUE_RETRY_BASE_DELAY_SECONDS=0.5
CUE_RETRY_MAX_DELAY_SECONDS=5.0
CUE_RETRY_JITTER_SECONDS=0.2
CUE_CIRCUIT_BREAKER_FAILURES=3
CUE_CIRCUIT_BREAKER_COOLDOWN_SECONDS=300

# --- Logging ---
EAP_LOG_LEVEL=INFO
EAP_LOG_FORMAT=json

