# ============================================================
# CueAgent Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Brain / LLM Providers ---

# Primary: OpenAI
CUE_OPENAI_API_KEY=sk-your-openai-key-here
CUE_OPENAI_MODEL=gpt-4o
CUE_OPENAI_BASE_URL=https://api.openai.com

# Fallback 1: Anthropic Claude
CUE_ANTHROPIC_API_KEY=sk-ant-your-key-here
CUE_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Fallback 2: OpenRouter (aggregator, OpenAI-compatible)
CUE_OPENROUTER_API_KEY=sk-or-your-key-here
CUE_OPENROUTER_MODEL=openai/gpt-4o
CUE_OPENROUTER_BASE_URL=https://openrouter.ai/api

# Fallback 3: LM Studio (local, always available, no key needed)
CUE_LMSTUDIO_BASE_URL=http://localhost:1234
CUE_LMSTUDIO_MODEL=local-model

# LLM behavior
CUE_LLM_TEMPERATURE=0.0
CUE_LLM_TIMEOUT_SECONDS=60
CUE_LLM_BUDGET_WARNING_USD=20.0
CUE_LLM_MONTHLY_BUDGET_USD=50.0
CUE_LLM_BUDGET_ENFORCE_HARD_STOP=true
CUE_LLM_COST_OPENAI_INPUT_PER_1K=0.005
CUE_LLM_COST_OPENAI_OUTPUT_PER_1K=0.015
CUE_LLM_COST_ANTHROPIC_INPUT_PER_1K=0.003
CUE_LLM_COST_ANTHROPIC_OUTPUT_PER_1K=0.015
CUE_LLM_COST_OPENROUTER_INPUT_PER_1K=0.003
CUE_LLM_COST_OPENROUTER_OUTPUT_PER_1K=0.010
CUE_LLM_COST_LMSTUDIO_INPUT_PER_1K=0.0
CUE_LLM_COST_LMSTUDIO_OUTPUT_PER_1K=0.0

# --- Communication / Telegram ---
CUE_TELEGRAM_BOT_TOKEN=your-telegram-bot-token
CUE_TELEGRAM_ADMIN_CHAT_ID=123456789
CUE_TELEGRAM_WEBHOOK_URL=
CUE_TELEGRAM_WEBHOOK_LISTEN_HOST=0.0.0.0
CUE_TELEGRAM_WEBHOOK_LISTEN_PORT=8081
CUE_TELEGRAM_WEBHOOK_PATH=/telegram/webhook
CUE_TELEGRAM_WEBHOOK_SECRET_TOKEN=
CUE_TELEGRAM_WEBHOOK_DROP_PENDING_UPDATES=false
CUE_NOTIFICATIONS_ENABLED=true
CUE_NOTIFICATION_DELIVERY_MODE=immediate
CUE_NOTIFICATION_PRIORITY_THRESHOLD=medium
CUE_NOTIFICATION_QUIET_HOURS_START=22
CUE_NOTIFICATION_QUIET_HOURS_END=7
CUE_NOTIFICATION_TIMEZONE=UTC
CUE_NOTIFICATION_HOURLY_DIGEST_CRON=0 * * * *
CUE_NOTIFICATION_DAILY_DIGEST_CRON=0 8 * * *

# --- Memory / State ---
CUE_STATE_DB_PATH=cue_state.db
CUE_SOUL_MD_PATH=SOUL.md
CUE_VECTOR_MEMORY_ENABLED=false
CUE_VECTOR_MEMORY_PATH=data/vector_memory
CUE_VECTOR_MEMORY_COLLECTION=cue_agent_memory
CUE_VECTOR_MEMORY_TOP_K=4
CUE_VECTOR_MEMORY_CONSOLIDATION_ENABLED=true
CUE_VECTOR_MEMORY_CONSOLIDATION_CRON=0 */6 * * *
CUE_VECTOR_MEMORY_CONSOLIDATION_MIN_ENTRIES=30
CUE_VECTOR_MEMORY_CONSOLIDATION_KEEP_RECENT=20
CUE_VECTOR_MEMORY_CONSOLIDATION_MAX_ITEMS=120

# --- Web Search ---
CUE_SEARCH_PROVIDER=auto
CUE_SEARCH_MAX_RESULTS=5
CUE_SEARCH_REGION=us-en
CUE_SEARCH_RATE_LIMIT_SECONDS=1.0
CUE_TAVILY_API_KEY=
CUE_SERPAPI_API_KEY=

# --- Heartbeat / Scheduler ---
CUE_HEARTBEAT_ENABLED=false
CUE_DAILY_SUMMARY_CRON=0 8 * * *

# --- Security ---
CUE_HIGH_RISK_TOOLS=["run_shell","write_file","send_telegram"]
CUE_APPROVAL_REQUIRED_LEVELS=["high","critical"]
CUE_RISK_RULES_PATH=skills/risk_rules.json
CUE_RISK_SANDBOX_DRY_RUN=false
CUE_REQUIRE_APPROVAL=true

# --- Skills ---
CUE_SKILLS_DIR=skills
CUE_SKILLS_HOT_RELOAD=true

# --- Autonomous Loop ---
CUE_LOOP_ENABLED=false
CUE_LOOP_INTERVAL_SECONDS=30
CUE_TASK_QUEUE_ENABLED=true
CUE_TASK_QUEUE_MAX_LIST=20
CUE_TASK_QUEUE_RETRY_FAILED_ATTEMPTS=2
CUE_TASK_QUEUE_AUTO_SUBTASKS_ENABLED=true
CUE_TASK_QUEUE_AUTO_SUBTASKS_MAX=3

# --- Health Endpoint (used by Docker/system checks) ---
CUE_HEALTHCHECK_ENABLED=true
CUE_HEALTHCHECK_HOST=0.0.0.0
CUE_HEALTHCHECK_PORT=8080
CUE_DASHBOARD_ENABLED=false
CUE_DASHBOARD_USERNAME=admin
CUE_DASHBOARD_PASSWORD=change-me
CUE_DASHBOARD_TIMELINE_LIMIT=200

# --- Audit Trail ---
CUE_AUDIT_RETENTION_DAYS=30
CUE_AUDIT_CLEANUP_CRON=15 3 * * *

# --- Retry / Resilience ---
CUE_RETRY_TOOL_ATTEMPTS=3
CUE_RETRY_TELEGRAM_ATTEMPTS=5
CUE_RETRY_LLM_ATTEMPTS=3
CUE_RETRY_BASE_DELAY_SECONDS=0.5
CUE_RETRY_MAX_DELAY_SECONDS=5.0
CUE_RETRY_JITTER_SECONDS=0.2
CUE_CIRCUIT_BREAKER_FAILURES=3
CUE_CIRCUIT_BREAKER_COOLDOWN_SECONDS=300

# --- EAP Overrides (optional) ---
EAP_LOG_LEVEL=INFO
EAP_LOG_FORMAT=json

# Optional per-module log levels (examples)
# CUE_LOG_LEVEL_APP=DEBUG
# CUE_LOG_LEVEL_BRAIN=DEBUG
# CUE_LOG_LEVEL_LOOP=DEBUG
# CUE_LOG_LEVEL_ACTIONS=INFO
# CUE_LOG_LEVEL_COMMS=INFO
